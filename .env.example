# Stats Database (local, managed by docker-compose)
STATS_DB_HOST=localhost
STATS_DB_PORT=5433
STATS_DB_NAME=hedera_stats
STATS_DB_USER=postgres
STATS_DB_PASSWORD=postgres

# Mirror Node Database (external, read-only)
MIRROR_NODE_HOST=
MIRROR_NODE_PORT=5432
MIRROR_NODE_DB=hedera_mainnet
MIRROR_NODE_USER=
MIRROR_NODE_PASSWORD=

# Optional: Prometheus endpoint for time-to-consensus metric
PROMETHEUS_ENDPOINT=
